# Application
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=3007
APP_DATABASE_HOST=127.0.0.1
APP_DATABASE_PORT=5432
APP_DATABASE_USERNAME=root
APP_DATABASE_PASSWORD=password
APP_DATABASE_NAME=ai_reports
APP_DATABASE_URL=postgres://root:password@127.0.0.1:5432/ai_reports
APP_DATABASE_MIGRATE_ON_STARTUP=false

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_COMPLETIONS_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_AUTHENTICATION_SCHEME=Bearer
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=30000
DEEPSEEK_MAX_INPUT_TOKENS=16000
DEEPSEEK_MAX_OUTPUT_TOKENS=2000
DEEPSEEK_TEMPERATURE=0.1

#Voyage AI API
VOYAGEAI_API_KEY=your-voyage-api-api-key

# Authentication
AUTH_BOOTSTRAP_ADMIN_TOKEN=change-me
API_KEY_PREFIX=air_test
API_KEY_HASH_ALGORITHM=sha256
API_KEY_DEFAULT_EXPIRATION_DAYS=0

# Backward-compatible aliases for the existing local config names.
DEEPSEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEK_AUTHENTICATION_TOKEN=Bearer

# Fineract Read-Only / Replica Database
FINERACT_DATABASE_HOST=127.0.0.1
FINERACT_DATABASE_PORT=5432
FINERACT_DATABASE_USERNAME=root
FINERACT_DATABASE_PASSWORD=password
FINERACT_DATABASE_NAME=fineract_default
FINERACT_DATABASE_URL=postgres://root:password@127.0.0.1:5432/fineract_default
FINERACT_DATABASE_MAX_CONNECTIONS=10
FINERACT_DATABASE_QUERY_TIMEOUT_MS=3000

# Redis - optional for short-lived cache, locks, rate limit, and active sessions.
REDIS_URL=redis://127.0.0.1:6380/0
REDIS_ENABLED=true

# Vector / Embedding - start with pgvector in the app database.
VECTOR_STORE=pgvector
VECTOR_DATABASE_URL=postgres://root:password@127.0.0.1:5432/ai_reports
EMBEDDING_PROVIDER=none
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=0

# Query / Report Guards
QUERY_DEFAULT_TIMEOUT_MS=3000
QUERY_MAX_ROWS=100
REPORT_DIRECT_TIMEOUT_MS=5000
REPORT_ASYNC_TIMEOUT_MS=60000
REPORT_MAX_DATE_RANGE_DAYS=366
REPORT_MAX_ITERATIONS=12
REPORT_MAX_PARALLEL_QUERIES=3

# Catalog / Knowledge
CATALOG_PATH=knowledge
QUERY_PATH=queries
CATALOG_VALIDATE_ON_STARTUP=true

# Observability
RUST_LOG=info,tower_http=debug,sqlx=warn
AUDIT_LOG_ENABLED=true
